# Copy file này thành .env và điền thông tin của bạn
#   cp .env.example .env   (hoặc chạy setup.ps1)

# ── Tài khoản ───────────────────────────────────────────
VORTEX_USERNAME=your_username_here
VORTEX_PASSWORD=your_password_here

# ── Chế độ hoạt động: battle | catch | both | tower | sidequest ──
MODE=battle

# Map để grind (xem danh sách tại wiki.pokemon-vortex.com)
MAP_URL=https://www.pokemon-vortex.com/map/1/

# Số trận tối đa (0 = vô hạn)
MAX_BATTLES=0

# Delay giữa các action khi di chuyển (giây)
ACTION_DELAY_MIN=1.0
ACTION_DELAY_MAX=3.0

# Dùng move nào khi battle (1-4)
PREFERRED_MOVE=1

# Headless mode (true = không hiện browser)
HEADLESS=false

# ── Nghỉ ngơi cho GPU ───────────────────────────────────
# Sau mỗi N trận (N random trong [MIN, MAX]) thì ngủ REST_HOURS giờ.
REST_ENABLED=true
REST_AFTER_MIN=230
REST_AFTER_MAX=300
REST_HOURS=2.0

# ── Web dashboard ───────────────────────────────────────
WEB_UI=true
WEB_HOST=127.0.0.1
WEB_PORT=8770
